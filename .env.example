# Copia este fichero como .env y rellena los valores
# El .env NUNCA debe subirse a Git (.gitignore lo excluye)

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=changeme
DB_NAME=draftleague
DB_USER=draftuser
DB_PASSWORD=draftpass

# ── JWT ───────────────────────────────────────────────────────────────────────
# REQUIRED. Generate with: openssl rand -base64 64
# The backend refuses to start without this value; never reuse the placeholder.
JWT_SECRET=CHANGEME_generate_with_openssl_rand_base64_64

# ── URL pública del backend (IP o dominio del servidor) ───────────────────────
# En local se usa localhost, en producción la IP/dominio del VPS
API_URL=http://localhost:8080
