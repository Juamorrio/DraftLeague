{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "APP_VARIANT": "development",
        "EXPO_PUBLIC_API_BASE": "http://localhost:8080"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_API_BASE": "https://draftleague-production.up.railway.app"
      }
    },
    "production": {
      "android": { "buildType": "app-bundle" },
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_API_BASE": "https://draftleague-production.up.railway.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
